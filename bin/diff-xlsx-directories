#!/usr/bin/env bash

set -euo pipefail

if ! command -v xlsx2csv >/dev/null 2>&1; then
    echo "Error: xlsx2csv is not installed or not in your PATH." >&2
    echo "Install it with: pip install --user xlsx2csv" >&2
    exit 1
fi

if [[ $# -ne 2 ]]; then
    echo "Usage: $(basename "$0") DIR1 DIR2" >&2
    exit 1
fi

DIR1=$1
DIR2=$2

if [[ ! -d "$DIR1" ]]; then
    echo "Error: '$DIR1' is not a directory." >&2
    exit 1
fi

if [[ ! -d "$DIR2" ]]; then
    echo "Error: '$DIR2' is not a directory." >&2
    exit 1
fi

# Use colordiff for displayed differences when available.
if command -v colordiff >/dev/null 2>&1; then
    DIFF_CMD=colordiff
else
    DIFF_CMD=diff
fi

status=0

# Compare all XLS/XLSX files found in either directory.
while IFS= read -r file; do
    file1="$DIR1/$file"
    file2="$DIR2/$file"

    echo "=== $file ==="

    if [[ ! -f "$file1" ]]; then
        echo "Only in $DIR2"
        status=1
        echo
        continue
    fi

    if [[ ! -f "$file2" ]]; then
        echo "Only in $DIR1"
        status=1
        echo
        continue
    fi

    # Convert both Excel files to CSV for a reliable text-based comparison.
    csv1="${file1%.*}.csv"
    csv2="${file2%.*}.csv"

    xlsx2csv "$file1" >"$csv1"
    xlsx2csv "$file2" >"$csv2"

    # Remove generated CSV files if they are identical; otherwise, keep them
    # for inspection and display their differences.
    if diff -u "$csv1" "$csv2" >/dev/null; then
        echo "Files are identical"
        rm -f "$csv1" "$csv2"
    else
        "$DIFF_CMD" -u "$csv1" "$csv2" || true
        status=1
    fi

    echo
done < <(
    find "$DIR1" "$DIR2" \
         -type f \( -iname '*.xlsx' -o -iname '*.xls' \) \
         -printf '%P\n' |
        sort -u
)

exit "$status"
