#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 2 ]]; then
    echo "Usage: $(basename "$0") DIR1 DIR2" >&2
    exit 1
fi

DIR1=$1
DIR2=$2

[[ -d "$DIR1" ]] || { echo "Error: '$DIR1' is not a directory." >&2; exit 1; }
[[ -d "$DIR2" ]] || { echo "Error: '$DIR2' is not a directory." >&2; exit 1; }

status=0

# Compare all XLS/XLSX files found in either directory.
find "$DIR1" "$DIR2" \
    -type f \( -iname '*.xlsx' -o -iname '*.xls' \) \
    -printf '%P\n' |
    sort -u |
    while read -r file; do

    file1="$DIR1/$file"
    file2="$DIR2/$file"

    echo "=== $file ==="

    if [[ ! -f "$file1" ]]; then
        echo "Only in $DIR2"
        status=1
        echo
        continue
    fi

    if [[ ! -f "$file2" ]]; then
        echo "Only in $DIR1"
        status=1
        echo
        continue
    fi

    if diff -u \
        <(xlsx2csv "$file1") \
        <(xlsx2csv "$file2") >/dev/null
    then
        echo "OK"
    else
        echo "DIFFER"
        diff -u \
            <(xlsx2csv "$file1") \
            <(xlsx2csv "$file2") || true
        status=1
    fi

    echo
done

exit $status
